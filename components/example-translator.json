{
  "id": "ai-translator",
  "name": "AI翻译助手",
  "version": "1.0.0",
  "description": "使用AI进行多语言翻译",
  "author": "用户",
  "tags": ["ai", "translate", "text"],
  "icon": "🌐",
  
  "tool": {
    "description": "将文本翻译为指定语言，支持多种语言互译",
    "parameters": [
      {
        "name": "text",
        "type": "string",
        "description": "需要翻译的文本内容",
        "required": true,
        "label": "输入文本",
        "placeholder": "请输入要翻译的文本"
      },
      {
        "name": "targetLang",
        "type": "enum",
        "description": "目标语言",
        "enum": ["英语", "中文", "日语", "韩语", "法语", "德语", "西班牙语"],
        "default": "英语",
        "required": true,
        "label": "翻译为"
      },
      {
        "name": "style",
        "type": "enum",
        "description": "翻译风格",
        "enum": ["正式", "口语", "学术", "文学"],
        "default": "正式",
        "label": "翻译风格"
      }
    ],
    "required": ["text", "targetLang"]
  },
  
  "executor": {
    "type": "llm",
    "llm": {
      "model": "gpt-4o",
      "systemPrompt": "你是一个专业的翻译专家。请根据用户指定的风格进行翻译，保持原文的语气和情感。翻译要准确、流畅、自然。",
      "userPrompt": "请将以下文本翻译为{{targetLang}}，使用{{style}}风格：\n\n{{text}}\n\n翻译结果：",
      "temperature": 0.3,
      "maxTokens": 2000
    },
    "timeout": 30000
  },
  
  "ui": {
    "visible": true,
    "layout": "vertical"
  }
}
