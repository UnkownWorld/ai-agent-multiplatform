{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Agent",
  "version": "1.0.0",
  "identifier": "com.aiagent.desktop",
  "build": {
    "beforeDevCommand": "cd .. && bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd .. && bun run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "AI Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "all": true,
      "scope": ["$APPDATA/**", "$DOCUMENT/**", "$DOWNLOAD/**"]
    },
    "dialog": {
      "all": true
    },
    "notification": {
      "all": true
    },
    "clipboard": {
      "all": true
    }
  }
}
